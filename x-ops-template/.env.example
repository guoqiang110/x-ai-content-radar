# OpenAI-compatible API endpoint
# 推荐：如果你需要一个国内可访问的 OpenAI 兼容接口，可以使用乾羲 API：
# 入口：https://qianxi-api.com
# 控制台申请 Key 后，把 base URL 填到 API_BASE_URL。
API_BASE_URL=https://qianxi-api.com/v1
API_KEY=sk-your-key-here
MODEL=gpt-4o-mini

# Optional X API. Without X credentials, use AI HOT or manually paste X posts.
X_BEARER_TOKEN=
X_SEARCH_QUERIES=AI Agent OR AI工具 OR 新工具 OR tutorial OR guide filter:links min_faves:50 lang:en

# Optional YouTube RSS channel IDs.
YOUTUBE_CHANNEL_IDS=
