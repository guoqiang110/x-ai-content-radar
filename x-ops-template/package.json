{
  "name": "x-ops",
  "version": "1.0.0",
  "description": "X 运营自动化 - Claude Code 大脑 + Codex 小弟",
  "main": "scripts/collect.js",
  "scripts": {
    "collect": "node scripts/collect.js",
    "summarize": "node scripts/summarize.js",
    "generate": "node scripts/generate.js",
    "daily": "node scripts/collect.js && node scripts/summarize.js",
    "rank": "node scripts/rank.js",
    "pack": "node scripts/generate-pack.js",
    "daily-pack": "node scripts/collect.js && node scripts/rank.js && node scripts/summarize.js && node scripts/generate-pack.js --rank=1",
    "aihot": "node scripts/collect-aihot.js",
    "daily-aihot-pack": "node scripts/collect-aihot.js && node scripts/rank.js && node scripts/generate-pack.js --rank=1",
    "agent": "node scripts/agent.js",
    "agent:full": "node scripts/agent.js --full",
    "agent:a": "node scripts/agents/a-curator.js",
    "agent:b": "node scripts/agents/b-writer.js",
    "agent:c": "node scripts/agents/c-media.js",
    "agent:d": "node scripts/agents/d-reviewer.js"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.4.0"
  }
}
